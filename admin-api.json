{
    "openapi": "3.1.0",
    "info": {
        "title": "Laravel",
        "version": "1.0.0",
        "description": "TB BE API documentation for admin and supplier endpoints."
    },
    "servers": [
        {
            "url": "http://localhost:8083",
            "description": "Local"
        }
    ],
    "paths": {
        "/admin/auth/login": {
            "post": {
                "operationId": "admin.auth.login",
                "description": "Admin kullanicisini giris yaptirir ve access token doner.",
                "summary": "Admin Login",
                "tags": [
                    "Admin Auth"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "description": "Admin e-posta adresi",
                                        "example": "admin@example.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "description": "Sifre",
                                        "example": "secret123"
                                    }
                                },
                                "required": [
                                    "email",
                                    "password"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "id": {
                                            "type": "integer"
                                        },
                                        "name": {
                                            "type": "string"
                                        },
                                        "email": {
                                            "type": "string"
                                        },
                                        "token": {
                                            "type": "string"
                                        },
                                        "permissions": {
                                            "type": "array",
                                            "items": {
                                                "type": "string"
                                            }
                                        },
                                        "token_iat": {
                                            "type": "string"
                                        },
                                        "token_exp": {
                                            "type": [
                                                "string",
                                                "null"
                                            ]
                                        }
                                    },
                                    "required": [
                                        "id",
                                        "name",
                                        "email",
                                        "token",
                                        "permissions",
                                        "token_iat",
                                        "token_exp"
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Hatali kimlik bilgisi",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "examples": [
                                        "Invalid credentials!"
                                    ],
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "message"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/admin/auth/forgot-password": {
            "post": {
                "operationId": "admin.auth.forgot-password",
                "description": "Admin kullanici icin sifre sifirlama baglantisi gonderir.",
                "summary": "Admin Forgot Password",
                "tags": [
                    "Admin Auth"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "description": "Admin e-posta adresi",
                                        "example": "admin@example.com"
                                    }
                                },
                                "required": [
                                    "email"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "examples": [
                                        "Sifre sifirlama baglantisi e-posta adresinize gonderildi."
                                    ],
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "message"
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation hatasi",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        },
                                        "errors": {
                                            "type": "object",
                                            "additionalProperties": {
                                                "type": "array",
                                                "items": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    },
                                    "required": [
                                        "message",
                                        "errors"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/admin/auth/reset-password": {
            "post": {
                "operationId": "admin.auth.reset-password",
                "description": "Token ile admin sifresini yeniler.",
                "summary": "Admin Reset Password",
                "tags": [
                    "Admin Auth"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "email": {
                                        "type": "string",
                                        "format": "email",
                                        "description": "Admin e-posta adresi",
                                        "example": "admin@example.com"
                                    },
                                    "token": {
                                        "type": "string",
                                        "description": "Sifre sifirlama tokeni",
                                        "example": "reset-token"
                                    },
                                    "password": {
                                        "type": "string",
                                        "format": "password",
                                        "description": "Yeni sifre",
                                        "example": "newSecret123"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "format": "password",
                                        "description": "Yeni sifre (tekrar)",
                                        "example": "newSecret123"
                                    }
                                },
                                "required": [
                                    "email",
                                    "token",
                                    "password",
                                    "password_confirmation"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "examples": [
                                        "Sifreniz basariyla guncellendi."
                                    ],
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "message"
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "description": "Validation hatasi",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        },
                                        "errors": {
                                            "type": "object",
                                            "additionalProperties": {
                                                "type": "array",
                                                "items": {
                                                    "type": "string"
                                                }
                                            }
                                        }
                                    },
                                    "required": [
                                        "message",
                                        "errors"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/admin/auth/me": {
            "get": {
                "operationId": "admin.auth.me",
                "description": "Token sahibi admin kullanicisinin profil bilgisini doner.",
                "summary": "Admin Me",
                "tags": [
                    "Admin Auth"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "id": {
                                            "type": "integer"
                                        },
                                        "name": {
                                            "type": "string"
                                        },
                                        "email": {
                                            "type": "string"
                                        },
                                        "permissions": {
                                            "type": "array",
                                            "items": {
                                                "type": "string"
                                            }
                                        }
                                    },
                                    "required": [
                                        "id",
                                        "name",
                                        "email",
                                        "permissions"
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Yetkisiz istek",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "examples": [
                                        "Unauthorized"
                                    ],
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "message"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/admin/auth/logout": {
            "post": {
                "operationId": "admin.auth.logout",
                "description": "Mevcut access tokeni iptal eder.",
                "summary": "Admin Logout",
                "tags": [
                    "Admin Auth"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "examples": [
                                        "Basariyla cikis yaptiniz."
                                    ],
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "message"
                                    ]
                                }
                            }
                        }
                    },
                    "401": {
                        "description": "Yetkisiz istek",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "examples": [
                                        "Unauthorized"
                                    ],
                                    "properties": {
                                        "message": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "message"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}